# ─────────────────────────── Database ───────────────────────────
# self-hosted: sslmode=require + شهادة CA صحيحة (راجع lib/db/ssl.ts)
DATABASE_URL=postgres://user:pass@host:5432/mawrid?sslmode=require
# شهادة CA للتحقق من SSL في الإنتاج. تدعم خيارين:
#  (أ) محتوى PEM مباشرة (يُقبل \n مهروب):
#      DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
#  (ب) مسار ملف شهادة مركّب:
#      DATABASE_CA_CERT="/etc/ssl/certs/postgres-ca.pem"
DATABASE_CA_CERT=""

# ───────────────────────── Better Auth ──────────────────────────
# إلزامي على السيرفر الذاتي (لا يوجد VERCEL_URL)
BETTER_AUTH_URL=https://app.client-domain.com
# ولّده: openssl rand -base64 32
BETTER_AUTH_SECRET=
# أصول موثوقة إضافية، مفصولة بفواصل (اختياري)
TRUSTED_ORIGINS=

# ───────────── Bootstrap admin (سكربت CLI فقط) ──────────────────
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ─────────────────────────── Flags ──────────────────────────────
# true في dev فقط. في الإنتاج false: الكتالوج يرجع فارغاً بدل بيانات وهمية.
ALLOW_MOCK_FALLBACK=false

# ميزات العرض التجريبي (دردشة، ولاء، قسائم...) — false في الإنتاج
NEXT_PUBLIC_DEMO_FEATURES=false

# ─────────────────────── AI / Gateway ───────────────────────────
# مفتاح بوابة الذكاء (image-search / recommendations)
AI_GATEWAY_API_KEY=
# سقف يومي لطلبات AI لكل مستخدم/IP (image-search)
AI_RATELIMIT_PER_MIN=10
# سقف يومي لكل مستخدم/IP للنقاط المكلفة
AI_RATELIMIT_PER_DAY=100

# ───────────────────────── Maps (اختياري) ───────────────────────
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=

# ─────────────────────────── Email ──────────────────────────────
# مزوّد البريد: Resend (https://resend.com) — إلزامي لإرسال روابط إعادة تعيين كلمة المرور
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# عنوان المرسل (يجب أن يكون على دومين موثّق في Resend)
EMAIL_FROM=noreply@mawrid.sa

# ─────────────────────── Security / Ops ─────────────────────────
# اضبطه true فقط خلف reverse proxy موثوق يعيد كتابة x-forwarded-for
RATE_LIMIT_TRUST_PROXY=false
# opt-in صريح لتخطّي التحقق من شهادة SSL في الإنتاج (يُفضّل DATABASE_CA_CERT بدلاً منه)
DATABASE_ALLOW_INSECURE_SSL=false
# أصول مسموح بها لـ CORS على /api/v1/* (مفصولة بفواصل)، أو same-origin إن فارغ
CORS_ORIGIN=https://mawrid.sa

# ─────────────── SEO / روابط عامة ───────────────
# الرابط العام المستخدم في canonical و sitemap و structured data
# (يعود إلى BETTER_AUTH_URL ثم localhost إن لم يُضبط)
NEXT_PUBLIC_SITE_URL=https://mawrid.sa

# ─────────────── SMS OTP (Twilio) — الميزة 10 ───────────────
# إن تُركت فارغة يُطبع رمز OTP في السجل للتطوير فقط
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─────────────── الدخول الاجتماعي — الميزة 14 ───────────────
# يُفعَّل كل مزوّد تلقائياً فقط عند توفّر مفاتيحه
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─────────────── إشعارات Push (Firebase) — لاحقاً ───────────────
FIREBASE_SERVICE_ACCOUNT_JSON=
